# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# Environment — never commit
.env
*.env

# Credentials — never commit
credentials/
*.json.credentials
youtube_token.json

# Brand configs (private — real values live on the deployed box only).
# The `brand/` dir is ALSO the working tree of a nested private git repo
# (glitch-grow-ai-social-media-agent-private). Its README.md and .gitignore
# are owned by that private repo and must NOT be tracked by this one.
brand.config.json
brand/configs/*.json
!brand/configs/.gitkeep
brand/prompts/*.md
!brand/prompts/.gitkeep
brand/audio/*
!brand/audio/.gitkeep
!brand/audio/README.md
brand/README.md
brand/.gitignore

# Generated videos — large binary files
/var/lib/glitch-signal/
*.mp4
*.mov

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Alembic
alembic/versions/*.pyc
.claude/
