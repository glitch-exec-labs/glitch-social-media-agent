# Brand configs (private — real values live on the deployed box only)
brand.config.json
brand/configs/*.json
!brand/configs/.gitkeep
brand/prompts/*.md
!brand/prompts/.gitkeep

# Generated videos — large binary files
/var/lib/glitch-signal/
*.mp4
*.mov

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Alembic
alembic/versions/*.pyc
