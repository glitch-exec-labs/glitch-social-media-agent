# Glitch Social Media Agent — environment config template
#
# This is THE single secrets + credentials file for the agent. Copy to .env
# and fill in values. Never commit .env — it is gitignored (.env and *.env).
# Any new third-party integration adds its credentials here, not in a
# sidecar file, not in brand/configs/*.json, and not in code.
#
# Layered config pattern, in order of concern:
#   - .env               → secrets + infra endpoints (this file; gitignored)
#   - brand/configs/*    → per-brand, non-secret tunables (gitignored,
#                          operator-managed on the deployed box)
#   - brand/schema/      → JSON Schema validating the above (committed)
#   - brand/configs.example/ → committed templates showing config shape
#
# Rotation policy: any leaked key goes through the provider's regenerate
# flow, then gets updated here. AUTH_ENCRYPTION_KEY is special — rotating
# it invalidates every row in platform_auth and requires re-running every
# OAuth handshake.

# Database
SIGNAL_DB_URL=postgresql+asyncpg://signal:changeme@127.0.0.1:5432/glitch_signal
GLITCH_RO_URL=  # Phase 2: read-only access to glitchexecutor DB

# LLMs
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
VERTEX_PROJECT=    # optional — leave empty to use AI Studio
VERTEX_LOCATION=us-central1

# Video models
KLING_API_KEY=
KLING_API_URL=https://api.klingai.com
RUNWAY_API_KEY=    # Phase 2
VEO_API_KEY=       # Phase 2
HAILUO_API_KEY=    # Phase 2

# Platforms
YOUTUBE_CLIENT_SECRETS_FILE=credentials/youtube_client_secrets.json
YOUTUBE_CHANNEL_ID=
# Phase 2:
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
IG_ACCESS_TOKEN=
IG_USER_ID=

# Telegram
TELEGRAM_BOT_TOKEN_SIGNAL=
TELEGRAM_ADMIN_IDS=  # comma-separated Telegram user IDs

# Storage
VIDEO_STORAGE_PATH=/var/lib/glitch-signal/videos

# Runtime
PUBLIC_BASE_URL=https://signal.glitchexecutor.com
DISPATCH_MODE=dry_run  # change to 'live' for production
LOG_LEVEL=INFO
SCHEDULER_TICK_MS=30000

# Scout (GitHub — ai_generated pipeline)
GITHUB_TOKEN=
GITHUB_ORG=glitch-exec-labs
GITHUB_REPOS=  # comma-separated repo names; leave empty to scan all org repos

# Google Drive (drive_footage content source)
# Service-account JSON with Drive readonly scope. Share each brand's Drive
# folder with the SA email (Viewer). Leave empty to disable drive_scout.
GOOGLE_DRIVE_SA_JSON=

# Brand (multi-brand)
#   - brand/configs/<brand_id>.json  → one file per brand, gitignored
#   - brand/configs.example/          → committed templates
#   - brand/schema/brand.config.schema.json  → validation schema
BRAND_CONFIGS_DIR=brand/configs
DEFAULT_BRAND_ID=glitch_executor
# Legacy single-file brand config path (still honoured if brand/configs/ is empty)
BRAND_CONFIG_PATH=brand.config.json

# OAuth + platform_auth encryption
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key invalidates every stored token — re-run every OAuth flow.
AUTH_ENCRYPTION_KEY=

# TikTok Content Posting API
#   Register the app at https://developers.tiktok.com
#   Redirect URI must match TIKTOK_REDIRECT_URI exactly.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://grow.glitchexecutor.com/oauth/tiktok/callback
TIKTOK_DEFAULT_SCOPES=user.info.basic,video.upload,video.publish
TIKTOK_POST_STATUS_TIMEOUT_S=180

# Make.com (automation platform — webhook triggers, scenario execution)
# Dashboard: https://us2.make.com
# API docs: https://developers.make.com/api-documentation
# Zone matters — token + base URL are zone-bound. Don't mix us1 / us2 / eu1 / eu2.
MAKE_BASE_URL=https://us2.make.com
MAKE_API_BASE=https://us2.make.com/api/v2
MAKE_ORG_ID=6650700
MAKE_API_TOKEN=

# Zernio (audited multi-platform social-posting API)
# Used when our own per-platform dev apps are unaudited (e.g. TikTok today).
# Dashboard: https://zernio.com  Docs: https://docs.zernio.com
ZERNIO_API_KEY=
ZERNIO_BASE_URL=https://zernio.com/api
